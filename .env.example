# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key # Only needed for seed scripts

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000  # Use http://triptrack.xyz in production

# Email Configuration (Resend)
# Get your API key from: https://resend.com/api-keys
# Note: Set this in Supabase Dashboard → Edge Functions → Environment Variables
# RESEND_API_KEY=re_xxx...
